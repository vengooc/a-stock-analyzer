/* 板块详情页样式 */

.container {
  min-height: 100vh;
  background-color: #1A1A2E;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48px;
}

/* 内容区 */
.content {
  padding: 12px;
  padding-bottom: 24px;
}

/* 板块概览 */
.board-overview {
  background-color: #16213E;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.overview-name {
  font-size: 20px;
  font-weight: 600;
  color: #FFFFFF;
}

.overview-change {
  font-size: 24px;
  font-weight: 600;
}

.overview-change.up {
  color: #E53935;
}

.overview-change.down {
  color: #43A047;
}

.overview-stats {
  display: flex;
  gap: 24px;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
}

.stat-label {
  font-size: 12px;
  color: #B0B0B0;
  margin-top: 4px;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  gap: 8px;
  padding: 12px 4px;
}

.sort-tag {
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 13px;
  color: #B0B0B0;
  background-color: rgba(255, 255, 255, 0.08);
  transition: all 0.2s ease;
}

.sort-tag.active {
  background-color: #FFD700;
  color: #1A1A2E;
  font-weight: 500;
}

/* 成分股列表 */
.stock-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  text-align: center;
}

.error-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.error-msg {
  font-size: 16px;
  font-weight: 600;
  color: #E53935;
  margin-bottom: 8px;
}

.error-detail {
  font-size: 12px;
  color: #B0B0B0;
  margin-bottom: 16px;
  line-height: 1.5;
  word-break: break-all;
}

.btn-retry {
  background: #FFD700;
  color: #1A1A2E;
  border: none;
  border-radius: 6px;
  padding: 8px 20px;
  font-size: 14px;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 24px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
  opacity: 0.6;
}

.empty-text {
  font-size: 14px;
  color: #B0B0B0;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 11px;
  color: #9E9E9E;
  font-family: 'Courier New', monospace;
}

/* 原 stock-list 样式 */
.stock-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.stock-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background-color: #16213E;
  border-radius: 8px;
}

.stock-rank {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  margin-right: 12px;
  flex-shrink: 0;
}

.stock-info {
  flex: 1;
  min-width: 0;
}

.stock-name {
  font-size: 15px;
  font-weight: 500;
  color: #FFFFFF;
  margin-bottom: 2px;
}

.stock-code {
  font-size: 12px;
  color: #B0B0B0;
}

.stock-data {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 12px;
}

.stock-price {
  margin-bottom: 2px;
}

.price-value {
  font-size: 15px;
  color: #FFFFFF;
  font-weight: 500;
}

.stock-change {
  font-size: 14px;
  font-weight: 500;
}

.stock-change.up {
  color: #E53935;
}

.stock-change.down {
  color: #43A047;
}

.stock-watch {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #B0B0B0;
  transition: all 0.2s ease;
}

.stock-watch.active {
  color: #FFD700;
}

.stock-watch:active {
  transform: scale(1.2);
}