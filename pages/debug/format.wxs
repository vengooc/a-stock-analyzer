// pages/debug/format.wxs
// WXML 中使用的格式化函数
// 注意：WXS 不支持 Number() 构造函数，需用 +value 或 parseFloat() 转换数字

/**
 * 格式化涨跌幅（带正负号）
 */
function fmtPct(value) {
  if (value == null || value === '') return '--';
  var n = +value;  // 用 +value 代替 Number(value)
  if (isNaN(n)) return '--';
  var sign = n > 0 ? '+' : '';
  return sign + n.toFixed(2);
}

/**
 * 格式化金额（元 -> 亿/万）
 */
function fmtAmount(value) {
  if (value == null || value === '' || value === undefined) return '--';
  var n = +value;
  if (isNaN(n)) return '--';
  if (n >= 100000000) {
    return (n / 100000000).toFixed(2) + '亿';
  } else if (n >= 10000) {
    return (n / 10000).toFixed(2) + '万';
  }
  return n.toFixed(2);
}

/**
 * 根据涨跌幅返回颜色类名
 */
function pctClass(value) {
  if (value == null || value === '') return 'neutral';
  var n = +value;
  if (isNaN(n)) return 'neutral';
  if (n > 0) return 'up';
  if (n < 0) return 'down';
  return 'neutral';
}

/**
 * 格式化数字（千分位）
 */
function fmtNumber(value, decimals) {
  if (value == null || value === '') return '--';
  var n = +value;
  if (isNaN(n)) return '--';
  decimals = decimals || 2;
  return n.toFixed(decimals);
}

/**
 * 取绝对值（用于资金流向条宽度）
 */
function abs(value) {
  if (value == null || value === '') return 0;
  var n = +value;
  if (isNaN(n)) return 0;
  return Math.abs(n);
}

module.exports = {
  fmtPct: fmtPct,
  fmtAmount: fmtAmount,
  fmtNumber: fmtNumber,
  abs: abs,
  pctClass: pctClass
};