/* 事件详情页样式 */

.container {
  min-height: 100vh;
  background-color: #1A1A2E;
  padding-bottom: 24px;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48px;
}

.content {
  padding: 12px;
}

/* 事件头部 */
.event-header {
  background-color: #16213E;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.event-type-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.event-type {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 11px;
  background-color: rgba(255, 215, 0, 0.15);
  color: #FFD700;
}

.event-sentiment {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
}

.event-sentiment.sentiment-A {
  background-color: rgba(229, 57, 53, 0.2);
  color: #E53935;
}

.event-sentiment.sentiment-B {
  background-color: rgba(255, 152, 0, 0.2);
  color: #FF9800;
}

.event-sentiment.sentiment-C {
  background-color: rgba(158, 158, 158, 0.2);
  color: #9E9E9E;
}

.event-title {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.4;
  margin-bottom: 12px;
}

.event-meta {
  font-size: 12px;
  color: #666;
}

.meta-divider {
  margin: 0 8px;
}

/* 区块 */
.section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #FFFFFF;
  margin-bottom: 12px;
  padding-left: 4px;
}

.event-summary {
  background-color: #16213E;
  border-radius: 8px;
  padding: 16px;
  font-size: 14px;
  color: #B0B0B0;
  line-height: 1.6;
}

/* 关联标的 */
.stock-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.stock-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background-color: #16213E;
  border-radius: 8px;
}

.stock-info {
  flex: 1;
}

.stock-name {
  font-size: 15px;
  color: #FFFFFF;
  font-weight: 500;
  margin-bottom: 2px;
}

.stock-code {
  font-size: 12px;
  color: #666;
}

.stock-change {
  font-size: 15px;
  font-weight: 500;
  margin-right: 12px;
}

.stock-change.up {
  color: #E53935;
}

.stock-change.down {
  color: #43A047;
}

.stock-relevance {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 11px;
  margin-right: 12px;
}

.relevance-high {
  background-color: rgba(229, 57, 53, 0.2);
  color: #E53935;
}

.relevance-mid {
  background-color: rgba(255, 152, 0, 0.2);
  color: #FF9800;
}

.relevance-low {
  background-color: rgba(158, 158, 158, 0.2);
  color: #9E9E9E;
}

.stock-watch {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #B0B0B0;
}

/* 关联板块 */
.board-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.board-tag {
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 13px;
  background-color: #16213E;
  color: #FFD700;
}