.container {
  padding-bottom: 120rpx;
}

.search-bar {
  padding: 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
  padding: 8rpx;
}

.section {
  margin-top: 20rpx;
}

.section-header {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stock-list {
  padding: 0 12rpx;
}

.stock-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.stock-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stock-name-wrap {
  display: flex;
  align-items: center;
}

.stock-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 16rpx;
}

.stock-code {
  font-size: 24rpx;
  color: #999;
}

.stock-market {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.stock-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 20rpx;
}

.stock-price-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stock-change {
  font-size: 26rpx;
  margin-top: 4rpx;
}

.stock-change.up {
  color: #ff4757;
}

.stock-change.down {
  color: #2ed573;
}

.stock-watch {
  font-size: 36rpx;
  color: #ddd;
  padding: 8rpx;
}

.stock-watch.active {
  color: #ffa502;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #ff6b6b;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}